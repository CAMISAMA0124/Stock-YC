/* ================================================
   ai-analysis.js вҖ” AI Stock Analysis Module
   Supports OpenAI, Google Gemini, Anthropic Claude
   ================================================ */

YC.ai = (() => {

    /* в”Җв”Җ Build prompt for a single holding в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function buildHoldingPrompt(holding, backtestStr = 'е°ҡз„Ўеӣһжё¬ж•ёж“ҡеҸҜз”Ё') {
        const { name, symbol, price, currency, changePct, tempScore, label, gainPct, shares, pe, divYield } = holding;
        const priceStr = price ? `${currency === 'TWD' ? 'NT$' : '$'}${price?.toFixed(2)}` : 'жңӘзҹҘ';
        const changeStr = changePct != null ? `${changePct >= 0 ? '+' : ''}${changePct.toFixed(2)}%` : 'жңӘзҹҘ';
        const tempInfo = tempScore != null ? `${tempScore}/100 (${label})` : 'жңӘзҹҘ';
        const gainStr = gainPct != null ? `${gainPct >= 0 ? '+' : ''}${gainPct.toFixed(2)}%` : 'жңӘзҹҘ';
        const myNote = YC.state.getNote(symbol);

        return `дҪ жҳҜдёҖдҪҚе°ҲжҘӯзҡ„иӯүеҲёжҠ•иіҮеҲҶжһҗеё«пјҢи«ӢйҮқе°Қд»ҘдёӢжЁҷзҡ„йҖІиЎҢи¶ЁеӢўеҲҶжһҗгҖҒеҹәжң¬йқўиЁәж–·иҲҮжҠ•иіҮе»әиӯ°пјҡ

гҖҗжЁҷзҡ„еҹәжң¬иіҮиЁҠгҖ‘
- еҗҚзЁұпјҡ${name} (${symbol.replace('.TW', '')})
- зӣ®еүҚеғ№ж јпјҡ${priceStr} | жјІи·Ңпјҡ${changeStr}
- жә«еәҰиЁҲи©•еҲҶпјҡ${tempInfo} (иЁ»пјҡ0=жҘөдҪҺдј°пјҢ100=жҘөй«ҳдј°)
- жң¬зӣҠжҜ” (P/E)пјҡ${pe ? pe.toFixed(1) + 'x' : 'жңӘзҹҘ'}
- иӮЎжҒҜж®–еҲ©зҺҮпјҡ${divYield ? divYield.toFixed(2) + '%' : 'жңӘзҹҘ'}
- жҲ‘зҡ„е ұй…¬зҺҮпјҡ${gainStr} | жҢҒиӮЎж•ёпјҡ${shares || 'жҡ«жңӘжҢҒжңү'}
- IBS зҹӯз·ҡжҢҮжЁҷпјҡ${price && holding.dayHigh && holding.dayLow ? YC.indicators.calculateIBS(price, holding.dayHigh, holding.dayLow)?.toFixed(2) || 'жңӘзҹҘ' : 'жңӘзҹҘ'} (иЁ»: <=0.2жҳ“еҸҚеҪҲ, >=0.8жҳ“еӣһжӘ”)

гҖҗеӣһжё¬иҲҮйҮҸеҢ–жҢҮжЁҷгҖ‘(йҒҺеҺ»2е№ҙж•ёж“ҡ)
${backtestStr}

гҖҗжҲ‘зҡ„жҠ•иіҮеӮҷиЁ»гҖ‘
${myNote || '(зӣ®еүҚз„ЎеӮҷиЁ»)'}

гҖҗи«ӢйҮқе°Қд»ҘдёӢе…§е®№еҲҶжһҗгҖ‘
1. **и¶ЁеӢўеҲӨе®ҡиҲҮе»әиӯ°**пјҡеҠ зўј / жҢҒжңү / жёӣзўј (и«Ӣж №ж“ҡжә«еәҰиЁҲиҲҮеӣһжё¬и¶ЁеӢўеҲӨж–·пјҢеҺҹеӣ зӮәдҪ•пјҹ)
2. **иІЎе ұиҲҮеҹәжң¬йқўй—ңйҚөй»һ**пјҡз°Ўиҝ°зҚІеҲ©еӢ•иғҪгҖҒP/E жҲ–ж®–еҲ©зҺҮзҡ„ж„Ҹзҫ©гҖӮ
3. **е°Қж•ҙй«”й…ҚзҪ®зҡ„еҪұйҹҝ**пјҡжҳҜеҗҰйҒ©еҗҲдҪңзӮәж ёеҝғжҢҒиӮЎжҲ–зҹӯжңҹж“ҚдҪңпјҹ
4. **йўЁйҡӘжҸҗзӨә**пјҡжіЁж„ҸдәӢй …гҖӮ

и«Ӣз”Ёз№Ғй«”дёӯж–ҮпјҢж јејҸжё…жҷ°з°ЎзӣҙпјҢйҮҚй»һжўқеҲ—пјҢзёҪзөҗеңЁ 250 еӯ—е…§гҖӮ`;
    }

    /* в”Җв”Җ Build portfolio summary prompt в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function buildPortfolioPrompt(holdings, sentimentScore) {
        const heatLabel = sentimentScore <= 30 ? 'жҘөеҶ·' : sentimentScore <= 55 ? 'йҒ©дёӯ' : sentimentScore <= 75 ? 'еҒҸзҶұ' : 'жҘөзҶұ';
        const names = holdings.map(h => `${h.name}(жә«еәҰ${h.tempScore || '?'})`).join('гҖҒ');
        return `дҪ жҳҜдёҖдҪҚиіҮж·ұзҗҶиІЎеҲҶжһҗеё«пјҢи«ӢйҮқе°Қд»ҘдёӢжҠ•иіҮзө„еҗҲзөҰдәҲе°ҲжҘӯзҡ„е…ЁеұҖе»әиӯ°гҖӮ

гҖҗеёӮе ҙз’°еўғгҖ‘з•¶еүҚеёӮе ҙжғ…з·’пјҡ${sentimentScore}/100 (${heatLabel})
гҖҗжҢҒеҖүжЁҷзҡ„гҖ‘${names}

и«Ӣз”Ёз№Ғй«”дёӯж–ҮпјҢйҮқе°Қд»ҘдёӢеҲҶжһҗпјҡ
1. ж•ҙй«”йўЁйҡӘй…ҚзҪ®е»әиӯ° (1-2ж®ө)
2. зӣ®еүҚжҳ    /* в”Җв”Җ Call Google Gemini API в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function callGemini(prompt, apiKey, onChunk) {
        // v1 is the stable endpoint for gemini-1.5 series
        const model = 'gemini-1.5-flash';
        const url = `https://generativelanguage.googleapis.com/v1/models/${model}:streamGenerateContent?alt=sse&key=${encodeURIComponent(apiKey)}`;
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }),
        });
        if (!res.ok) {
            let errorText = '';
            try { 
                const err = await res.json();
                errorText = err?.error?.message || JSON.stringify(err);
            } catch(e) {
                errorText = await res.text();
            }
            // Fallback trial for v1beta if v1 fails with 404 (some legacy keys)
            if (res.status === 404) {
               return callGeminiV1Beta(prompt, apiKey, onChunk);
            }
            throw new Error(`Gemini API йҢҜиӘӨ (${res.status}): ${errorText}`);
        }
        return readStream(res, onChunk, 'gemini');
    }

    /* в”Җв”Җ Fallback for v1beta в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function callGeminiV1Beta(prompt, apiKey, onChunk) {
        const model = 'gemini-1.5-flash';
        const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?alt=sse&key=${encodeURIComponent(apiKey)}`;
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }),
        });
        if (!res.ok) {
            const err = await res.json();
            throw new Error(err?.error?.message || `Gemini v1beta Error ${res.status}`);
        }
        return readStream(res, onChunk, 'gemini');
    }

    /* в”Җв”Җ Stream reader (SSE) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function readStream(res, onChunk, provider) {
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let fullText = '';
        let buffer = '';

        try {
            while (true) {
                const { done, value } = await reader.read();
                if (done) break;
                buffer += decoder.decode(value, { stream: true });
                const lines = buffer.split('\n');
                buffer = lines.pop(); // keep incomplete last line

                for (const line of lines) {
                    const trimmedLine = line.trim();
                    if (!trimmedLine || !trimmedLine.startsWith('data:')) continue;
                    
                    const data = trimmedLine.slice(5).trim();
                    if (data === '[DONE]') break;
                    try {
                        const json = JSON.parse(data);
                        let chunk = '';
                        // Generic path for Gemini/OpenAI SSE format
                        chunk = json?.candidates?.[0]?.content?.parts?.[0]?.text || 
                                json?.choices?.[0]?.delta?.content || 
                                json?.delta?.text || '';
                        
                        if (chunk) {
                            fullText += chunk;
                            if (onChunk) onChunk(chunk, fullText);
                        }
                    } catch (e) {
                        // Metadata or partial JSON chunks - ignore
                    }
                }
            }
        } catch(e) {
            throw e;
        }
        return fullText;
    }

    /* в”Җв”Җ Main analyze function в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function analyze(holding, { onChunk, onDone, onError } = {}) {
        const settings = YC.state.get().settings;
        const apiKey = settings.apiKeyGemini || settings.apiKey;

        if (!apiKey) {
            if (onError) onError('и«Ӣе…ҲиЁӯе®ҡ Gemini API Key');
            return;
        }

        let backtestStr = 'е°ҡз„Ўеӣһжё¬ж•ёж“ҡеҸҜз”Ё';
        try {
            const bt = await YC.api.getBacktest(holding.symbol, 2);
            if (bt && bt.rating) {
                const s = bt.statistics || {};
                const r = bt.rating;
                backtestStr = `- жҢҒиӮЎи©•зӯү: ${r.label}\n- иҝ‘30ж—ҘдёҠжјІж©ҹзҺҮ: ${s.winRate?.['30d'] || 'жңӘзҹҘ'}\n- 30ж—Ҙе№іеқҮе ұй…¬зҺҮ: ${s.avgReturn?.['30d'] || 'жңӘзҹҘ'}\n- и©•еҲҶдҫқж“ҡ: ${(r.reason || []).join('гҖҒ')}`;
            }
        } catch (e) {
            console.warn('AI failed to load backtest data for prompt', e);
        }

        const prompt = buildHoldingPrompt(holding, backtestStr);
        try {
            const text = await callGemini(prompt, apiKey, onChunk);
            if (!text && !onChunk) throw new Error('AI жңӘеӣһеӮіе…§е®№');
            if (onDone) onDone(text);
            return text;
        } catch (e) {
            if (onError) onError(`AI еҲҶжһҗеӨұж•—пјҡ${e.message}`);
            return `Error: ${e.message}`;
        }
    }

    /* в”Җв”Җ Analyze full portfolio в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function analyzePortfolio(holdings, { onChunk, onDone, onError } = {}) {
        const settings = YC.state.get().settings;
        const apiKey = settings.apiKeyGemini || settings.apiKey;

        if (!apiKey) { if (onError) onError('и«Ӣе…ҲиЁӯе®ҡ Gemini API Key'); return; }

        const sentiment = YC.state.get().sentiment;
        const score = sentiment?.composite || 50;
        const prompt = buildPortfolioPrompt(holdings, score);
        try {
            const text = await callGemini(prompt, apiKey, onChunk);
            if (onDone) onDone(text);
            return text;
        } catch (e) {
            if (onError) onError(`AI еҲҶжһҗеӨұж•—пјҡ${e.message}`);
        }
    }

    /* в”Җв”Җ Test API connection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function testConnection(provider, apiKey) {
        const testPrompt = 'и«ӢеӣһиҰҶгҖҢйҖЈз·ҡжҲҗеҠҹгҖҚеҚіеҸҜгҖӮ';
        try {
            const result = await callGemini(testPrompt, apiKey, null);
            return { ok: true, message: result.trim() || 'йҖЈз·ҡжҲҗеҠҹ' };
        } catch (e) {
            return { ok: false, message: e.message };
        }
    }

    return { analyze, analyzePortfolio, testConnection };
})();2);
            if (bt && bt.rating) {
                const s = bt.statistics || {};
                const r = bt.rating;
                backtestStr = `- жҢҒиӮЎи©•зӯү: ${r.label}\n- иҝ‘30ж—ҘдёҠжјІж©ҹзҺҮ: ${s.winRate?.['30d'] || 'жңӘзҹҘ'}\n- 30ж—Ҙе№іеқҮе ұй…¬зҺҮ: ${s.avgReturn?.['30d'] || 'жңӘзҹҘ'}\n- и©•еҲҶдҫқж“ҡ: ${(r.reason || []).join('гҖҒ')}`;
            }
        } catch (e) {
            console.warn('AI failed to load backtest data for prompt', e);
        }

        const prompt = buildHoldingPrompt(holding, backtestStr);
        try {
            let text;
            if (provider === 'openai') text = await callOpenAI(prompt, apiKey, onChunk);
            else if (provider === 'gemini') text = await callGemini(prompt, apiKey, onChunk);
            else if (provider === 'claude') text = await callClaude(prompt, apiKey, onChunk);
            else throw new Error('дёҚж”ҜжҸҙзҡ„ AI дҫӣжҮүе•Ҷ: ' + provider);
            
            if (!text && !onChunk) throw new Error('AI жңӘеӣһеӮіе…§е®№');
            
            if (onDone) onDone(text);
            return text;
        } catch (e) {
            const msg = `AI еҲҶжһҗеӨұж•—пјҡ${e.message}`;
            console.error('AI Analysis Error Detail:', e);
            if (onError) onError(msg);
            return msg;
        }
    }

    /* в”Җв”Җ Analyze full portfolio в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function analyzePortfolio(holdings, { onChunk, onDone, onError } = {}) {
        const settings = YC.state.get().settings;
        const provider = settings.aiProvider || 'gemini';
        
        let apiKey = settings.apiKey;
        if (provider === 'openai' && settings.apiKeyOpenAI) apiKey = settings.apiKeyOpenAI;
        else if (provider === 'gemini' && settings.apiKeyGemini) apiKey = settings.apiKeyGemini;
        else if (provider === 'claude' && settings.apiKeyClaude) apiKey = settings.apiKeyClaude;

        if (!apiKey) { if (onError) onError('и«Ӣе…ҲиЁӯе®ҡ API Key'); return; }

        const sentiment = YC.state.get().sentiment;
        const score = sentiment?.composite || 50;
        const prompt = buildPortfolioPrompt(holdings, score);
        try {
            let text;
            if (provider === 'openai') text = await callOpenAI(prompt, apiKey, onChunk);
            else if (provider === 'gemini') text = await callGemini(prompt, apiKey, onChunk);
            else text = await callClaude(prompt, apiKey, onChunk);
            if (onDone) onDone(text);
            return text;
        } catch (e) {
            const msg = `AI еҲҶжһҗеӨұж•—пјҡ${e.message}`;
            if (onError) onError(msg);
        }
    }

    /* в”Җв”Җ Test API connection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    async function testConnection(provider, apiKey) {
        const testPrompt = 'и«Ӣз”Ё1еҸҘи©ұдёӯж–ҮеӣһиҰҶгҖҢйҖЈз·ҡжҲҗеҠҹгҖҚеҚіеҸҜгҖӮ';
        try {
            let result = '';
            if (provider === 'openai') result = await callOpenAI(testPrompt, apiKey, null);
            else if (provider === 'gemini') result = await callGemini(testPrompt, apiKey, null);
            else result = await callClaude(testPrompt, apiKey, null);
            return { ok: true, message: result.trim() || 'йҖЈз·ҡжҲҗеҠҹ' };
        } catch (e) {
            return { ok: false, message: e.message };
        }
    }

    return { analyze, analyzePortfolio, testConnection };
})();