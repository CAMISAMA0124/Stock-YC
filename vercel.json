{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "index.css",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.json",
      "use": "@vercel/static"
    },
    {
      "src": "sw.js",
      "use": "@vercel/static"
    },
    {
      "src": "icon.png",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/js/(.*)",
      "dest": "js/$1"
    },
    {
      "src": "/index.css",
      "dest": "index.css"
    },
    {
      "src": "/manifest.json",
      "dest": "manifest.json"
    },
    {
      "src": "/sw.js",
      "dest": "sw.js"
    },
    {
      "src": "/icon.png",
      "dest": "icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
